<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('dashboard') %> | <%= t('site_name') %></title>
    <style>
        /* Same styles as before, add language switcher styling */
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', sans-serif; }
        body { background: #0a0f1e; color: #fff; }
        .dashboard-container { max-width: 1400px; margin: 0 auto; padding: 20px; }
        .dashboard-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            background: rgba(255,255,255,0.05);
            padding: 15px 25px;
            border-radius: 15px;
            margin-bottom: 30px;
        }
        .user-info h3 { color: #00ff88; }
        .balance-card {
            background: linear-gradient(135deg, #1a2a3a, #0a1a2a);
            padding: 20px 30px;
            border-radius: 20px;
            text-align: center;
            border: 1px solid rgba(0,255,136,0.3);
        }
        .balance-amount { font-size: 42px; font-weight: bold; color: #00ff88; }
        .plans-section { margin: 40px 0; }
        .plan-category {
            background: rgba(255,255,255,0.03);
            border-radius: 20px;
            padding: 25px;
            margin-bottom: 30px;
        }
        .plan-category h2 { margin-bottom: 20px; color: #ffcc00; }
        .plan-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
        }
        .plan-card {
            background: rgba(0,0,0,0.5);
            border-radius: 15px;
            padding: 20px;
            border: 1px solid rgba(0,255,136,0.2);
            transition: 0.3s;
        }
        .plan-card:hover { transform: translateY(-5px); border-color: #00ff88; }
        .plan-range { font-size: 20px; font-weight: bold; margin: 10px 0; }
        .plan-profit { color: #00ff88; font-size: 18px; }
        .invest-btn {
            background: #00ff88;
            color: #0a0f1e;
            border: none;
            padding: 10px 20px;
            border-radius: 50px;
            cursor: pointer;
            margin-top: 15px;
            font-weight: bold;
        }
        .referral-box {
            background: linear-gradient(135deg, #1e2a3a, #0e1a2a);
            border-radius: 20px;
            padding: 25px;
            margin: 30px 0;
            text-align: center;
        }
        .referral-code {
            background: #0a0f1e;
            padding: 15px;
            border-radius: 10px;
            font-size: 24px;
            letter-spacing: 2px;
            margin: 15px auto;
            display: inline-block;
        }
        .action-buttons {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin: 30px 0;
            flex-wrap: wrap;
        }
        .action-btn {
            padding: 12px 25px;
            border-radius: 50px;
            border: none;
            font-weight: bold;
            cursor: pointer;
        }
        .deposit-btn { background: #00aaff; color: white; }
        .withdraw-btn { background: #ffaa00; color: #0a0f1e; }
        .task-btn { background: #00ff88; color: #0a0f1e; }
        .lang-btn {
            background: rgba(255,255,255,0.1);
            border: none;
            padding: 5px 12px;
            border-radius: 20px;
            color: white;
            cursor: pointer;
        }
        .modal { display: none; position: fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); justify-content:center; align-items:center; z-index:1000; }
        .modal-content { background:#1a2a3a; padding:30px; border-radius:20px; max-width:500px; width:90%; max-height:80vh; overflow-y:auto; }
        .close { float:right; font-size:28px; cursor:pointer; }
        .toast { position:fixed; bottom:20px; right:20px; background:#00ff88; color:#0a0f1e; padding:15px 25px; border-radius:10px; z-index:2000; animation:slideIn 0.3s; }
        @keyframes slideIn { from { transform:translateX(100%); opacity:0; } to { transform:translateX(0); opacity:1; } }
        @media (max-width:768px) { .dashboard-header { flex-direction: column; gap:15px; } }
    </style>
</head>
<body>
    <div class="dashboard-container">
        <div class="dashboard-header">
            <div class="user-info">
                <h3 id="userName">Loading...</h3>
                <p><%= t('referral_code') %>: <strong id="refCode">-</strong></p>
                <p><%= t('referral_section') %>: <span id="refCount">0</span></p>
            </div>
            <div class="balance-card">
                <p><%= t('balance') %></p>
                <div class="balance-amount" id="userBalance">0 CFA</div>
                <small><%= t('total_invested') %>: <span id="totalInvested">0</span> CFA</small>
            </div>
            <div style="display: flex; gap: 10px;">
                <button class="lang-btn" onclick="setLanguage('en')">🇬🇧 EN</button>
                <button class="lang-btn" onclick="setLanguage('fr')">🇫🇷 FR</button>
                <button class="action-btn" onclick="logout()" style="background:#ff4444; color:white;"><%= t('logout') %></button>
            </div>
        </div>
        
        <div class="action-buttons">
            <button class="action-btn deposit-btn" onclick="openDepositModal()">💰 <%= t('deposit') %></button>
            <button class="action-btn withdraw-btn" onclick="openWithdrawModal()">💸 <%= t('withdraw') %></button>
            <button class="action-btn task-btn" onclick="completeDailyTask()">✅ <%= t('daily_task') %></button>
        </div>
        
        <div class="plans-section" id="plansContainer"></div>
        
        <div class="referral-box">
            <h3>🎁 <%= t('referral_section') %></h3>
            <p><%= t('referral_desc') %></p>
            <div class="referral-code" id="referralLink">Loading...</div>
            <button class="invest-btn" onclick="copyReferral()"><%= t('copy_link') %></button>
        </div>
        
        <div id="activeInvestments"></div>
    </div>
    
    <!-- Deposit Modal -->
    <div id="depositModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeDepositModal()">&times;</span>
            <h2><%= t('deposit_title') %></h2>
            <div class="form-group">
                <label><%= t('country') %></label>
                <select id="depositCountry" onchange="updatePaymentMethods()">
                    <option value="Cameroon">Cameroon</option>
                    <option value="Chad">Chad</option>
                    <option value="Congo Brazzaville">Congo Brazzaville</option>
                    <option value="Gabon">Gabon</option>
                    <option value="Central African Republic">Central African Republic</option>
                </select>
            </div>
            <div class="form-group">
                <label><%= t('payment_method') %></label>
                <select id="paymentMethod"></select>
            </div>
            <div class="form-group">
                <label><%= t('account_number') %></label>
                <input type="text" id="accountNumber" placeholder="Enter your account number">
            </div>
            <div class="form-group">
                <label><%= t('amount') %></label>
                <input type="number" id="depositAmount" placeholder="Minimum 1000">
            </div>
            <button class="invest-btn" onclick="submitDeposit()"><%= t('submit_deposit') %></button>
            <p style="margin-top:15px; font-size:12px;"><%= t('deposit_note') %></p>
        </div>
    </div>
    
    <!-- Withdraw Modal -->
    <div id="withdrawModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeWithdrawModal()">&times;</span>
            <h2><%= t('withdraw_title') %></h2>
            <div class="form-group">
                <label><%= t('payment_method') %></label>
                <select id="withdrawMethod">
                    <option value="Orange Money">Orange Money</option>
                    <option value="MTN Mobile Money">MTN Mobile Money</option>
                    <option value="Airtel Money">Airtel Money</option>
                </select>
            </div>
            <div class="form-group">
                <label><%= t('account_number') %></label>
                <input type="text" id="withdrawAccount" placeholder="Your phone number">
            </div>
            <div class="form-group">
                <label><%= t('amount') %></label>
                <input type="number" id="withdrawAmount" placeholder="<%= t('withdraw_min') %>">
            </div>
            <button class="invest-btn" onclick="submitWithdraw()"><%= t('submit_withdraw') %></button>
        </div>
    </div>
    
    <script>
        async function setLanguage(lang) {
            await fetch('/api/set-language', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ lang })
            });
            location.reload();
        }

        let currentUser = null;
        let investmentPlans = null;
        
        async function loadUserData() {
            const res = await fetch('/api/me');
            if (res.status === 401) window.location.href = '/';
            currentUser = await res.json();
            document.getElementById('userName').innerHTML = `👋 ${currentUser.fullname}`;
            document.getElementById('userBalance').innerHTML = `${currentUser.balance.toLocaleString()} CFA`;
            document.getElementById('totalInvested').innerHTML = currentUser.totalInvested.toLocaleString();
            document.getElementById('refCode').innerHTML = currentUser.referralCode;
            document.getElementById('refCount').innerHTML = currentUser.referrals;
            document.getElementById('referralLink').innerHTML = `${window.location.origin}/?ref=${currentUser.referralCode}`;
            loadActiveInvestments();
        }
        
        async function loadInvestmentPlans() {
            const res = await fetch('/api/investment-plans');
            investmentPlans = await res.json();
            renderPlans();
        }
        
        function renderPlans() {
            const container = document.getElementById('plansContainer');
            container.innerHTML = '';
            for (const [key, category] of Object.entries(investmentPlans)) {
                const categoryDiv = document.createElement('div');
                categoryDiv.className = 'plan-category';
                let planLabel = '';
                if (key === '3day') planLabel = '3 <%= t("days_plan") %>';
                else if (key === '1week') planLabel = '1 <%= t("week_plan") %>';
                else planLabel = '1 <%= t("month_plan") %>';
                categoryDiv.innerHTML = `<h2>📈 ${planLabel}</h2><div class="plan-grid"></div>`;
                const grid = categoryDiv.querySelector('.plan-grid');
                category.plans.forEach(plan => {
                    const card = document.createElement('div');
                    card.className = 'plan-card';
                    card.innerHTML = `
                        <h3><%= t('plan') %> ${plan.id}</h3>
                        <div class="plan-range">${plan.min.toLocaleString()} - ${plan.max.toLocaleString()} CFA</div>
                        <div class="plan-profit"><%= t('profit') %>: +${plan.profit.toLocaleString()} CFA</div>
                        <button class="invest-btn" onclick="invest('${key}', '${plan.id}', ${plan.min}, ${plan.max})"><%= t('invest_now') %></button>
                    `;
                    grid.appendChild(card);
                });
                container.appendChild(categoryDiv);
            }
        }
        
        async function invest(planType, planId, minAmount, maxAmount) {
            let amount = prompt(`Enter investment amount (${minAmount.toLocaleString()} - ${maxAmount.toLocaleString()} CFA):`);
            amount = parseFloat(amount);
            if (isNaN(amount) || amount < minAmount || amount > maxAmount) {
                alert(`Invalid amount. Must be between ${minAmount.toLocaleString()} and ${maxAmount.toLocaleString()} CFA.`);
                return;
            }
            const res = await fetch('/api/invest', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ planType, planId, amount })
            });
            const data = await res.json();
            if (data.success) {
                showToast(`<%= t('investment_success') %> ${data.balance.toLocaleString()} CFA`);
                loadUserData();
                loadActiveInvestments();
            } else {
                alert('Investment failed: ' + data.error);
            }
        }
        
        async function loadActiveInvestments() {
            const res = await fetch('/api/my-investments');
            const investments = await res.json();
            const container = document.getElementById('activeInvestments');
            if (investments.length === 0) {
                container.innerHTML = `<p style="text-align:center;"><%= t('no_investments') %></p>`;
                return;
            }
            container.innerHTML = `<h3>📊 <%= t('active_investments') %></h3><div class="plan-grid">`;
            investments.forEach(inv => {
                container.innerHTML += `
                    <div class="plan-card">
                        <strong>${inv.planType.toUpperCase()} Plan</strong><br>
                        Amount: ${inv.amount.toLocaleString()} CFA<br>
                        Daily Reward: ${inv.dailyReturn.toLocaleString()} CFA<br>
                        <%= t('days_left') %>: ${inv.remainingDays}<br>
                        <%= t('status') %>: ${inv.status}
                    </div>
                `;
            });
            container.innerHTML += '</div>';
        }
        
        async function completeDailyTask() {
            const investmentsRes = await fetch('/api/my-investments');
            const investments = await investmentsRes.json();
            const activeInvest = investments.find(i => i.status === 'active');
            if (!activeInvest) {
                alert('<%= t("task_fail") %>');
                return;
            }
            const res = await fetch('/api/complete-task', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ investmentId: activeInvest.id })
            });
            const data = await res.json();
            if (data.success) {
                showToast(`✅ <%= t('task_success') %> ${data.reward.toLocaleString()} CFA. <%= t('investment_success') %> ${data.balance.toLocaleString()} CFA`);
                loadUserData();
                loadActiveInvestments();
            } else {
                alert('<%= t("task_fail") %>: ' + data.error);
            }
        }
        
        function openDepositModal() {
            updatePaymentMethods();
            document.getElementById('depositModal').style.display = 'flex';
        }
        function closeDepositModal() { document.getElementById('depositModal').style.display = 'none'; }
        function openWithdrawModal() { document.getElementById('withdrawModal').style.display = 'flex'; }
        function closeWithdrawModal() { document.getElementById('withdrawModal').style.display = 'none'; }
        
        function updatePaymentMethods() {
            const country = document.getElementById('depositCountry').value;
            const paymentMethods = {
                'Cameroon': ['Orange Money', 'MTN Mobile Money', 'Express Union'],
                'Chad': ['Airtel Money', 'Tigo Cash', 'Moov Africa'],
                'Congo Brazzaville': ['Airtel Money Congo', 'MTN Mobile Money', 'EcoCash'],
                'Gabon': ['Airtel Money Gabon', 'Moov Money'],
                'Central African Republic': ['Orange Money CAR', 'Telecel Cash']
            };
            const methods = paymentMethods[country];
            const select = document.getElementById('paymentMethod');
            select.innerHTML = methods.map(m => `<option value="${m}">${m}</option>`).join('');
        }
        
        async function submitDeposit() {
            const country = document.getElementById('depositCountry').value;
            const paymentMethod = document.getElementById('paymentMethod').value;
            const accountNumber = document.getElementById('accountNumber').value;
            const amount = document.getElementById('depositAmount').value;
            const res = await fetch('/api/deposit', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ country, paymentMethod, accountNumber, amount })
            });
            const data = await res.json();
            if (data.success) {
                alert(`Deposit request submitted! Funds will be credited within ${data.timer} hours.`);
                closeDepositModal();
            } else {
                alert('Error: ' + data.error);
            }
        }
        
        async function submitWithdraw() {
            const paymentMethod = document.getElementById('withdrawMethod').value;
            const accountNumber = document.getElementById('withdrawAccount').value;
            const amount = document.getElementById('withdrawAmount').value;
            const res = await fetch('/api/withdraw', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ amount, paymentMethod, accountNumber })
            });
            const data = await res.json();
            if (data.success) {
                alert('Withdrawal request submitted. Processing within 24 hours.');
                closeWithdrawModal();
                loadUserData();
            } else {
                alert('Error: ' + data.error);
            }
        }
        
        function copyReferral() {
            const link = document.getElementById('referralLink').innerText;
            navigator.clipboard.writeText(link);
            showToast('<%= t("copy_success") %>');
        }
        
        function showToast(msg) {
            const toast = document.createElement('div');
            toast.className = 'toast';
            toast.innerText = msg;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }
        
        function logout() {
            fetch('/api/logout', { method: 'POST' }).then(() => window.location.href = '/');
        }
        
        function showRandomWithdrawalNotif() {
            fetch('/api/random-withdrawal-notification')
                .then(res => res.json())
                .then(data => {
                    const toast = document.createElement('div');
                    toast.className = 'toast';
                    toast.style.background = '#ffaa00';
                    toast.style.color = '#000';
                    toast.innerHTML = `💰 ${data.user} from ${data.country} just withdrew ${data.amount.toLocaleString()} CFA!`;
                    document.body.appendChild(toast);
                    setTimeout(() => toast.remove(), 5000);
                });
        }
        
        setInterval(showRandomWithdrawalNotif, 25000);
        loadUserData();
        loadInvestmentPlans();
        updatePaymentMethods();
    </script>
</body>
</html>
