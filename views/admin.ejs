<!-- ==================== views/admin.ejs ==================== -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel | WealthPrime Invest</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', sans-serif; }
        body { background: #0a0f1e; color: #fff; padding: 20px; }
        .admin-container { max-width: 1400px; margin: 0 auto; }
        .login-box {
            background: rgba(255,255,255,0.1);
            padding: 40px;
            border-radius: 20px;
            max-width: 400px;
            margin: 100px auto;
        }
        .admin-header { display: flex; justify-content: space-between; margin-bottom: 30px; }
        table { width: 100%; border-collapse: collapse; background: rgba(255,255,255,0.05); border-radius: 10px; overflow: hidden; }
        th, td { padding: 12px; text-align: left; border-bottom: 1px solid rgba(255,255,255,0.1); }
        th { background: #00ff88; color: #0a0f1e; }
        input, select, button { padding: 8px 12px; border-radius: 8px; border: none; margin: 5px; }
        button { background: #00ff88; cursor: pointer; font-weight: bold; }
        .approve-btn { background: #00cc66; }
        .reject-btn { background: #ff4444; color: white; }
        .tabs { display: flex; gap: 10px; margin-bottom: 20px; }
        .tab { padding: 10px 20px; background: rgba(255,255,255,0.1); cursor: pointer; border-radius: 10px; }
        .tab.active { background: #00ff88; color: #0a0f1e; }
        .panel { display: none; }
        .panel.active { display: block; }
    </style>
</head>
<body>
    <div class="admin-container" id="adminApp">
        <div id="loginScreen" class="login-box">
            <h2>Admin Login</h2>
            <input type="password" id="adminPass" placeholder="Enter password" style="width:100%; margin:15px 0;">
            <button onclick="adminLogin()">Login</button>
        </div>
        
        <div id="adminPanel" style="display:none;">
            <div class="admin-header">
                <h1>WealthPrime Admin</h1>
                <button onclick="logoutAdmin()">Logout</button>
            </div>
            <div class="tabs">
                <div class="tab active" onclick="showTab('users')">Users</div>
                <div class="tab" onclick="showTab('transactions')">Pending Transactions</div>
            </div>
            
            <div id="usersPanel" class="panel active">
                <h3>All Users</h3>
                <table id="usersTable">
                    <thead>
                        <tr><th>Name</th><th>Email</th><th>Country</th><th>Balance</th><th>Referrals</th><th>Actions</th></tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
            
            <div id="transactionsPanel" class="panel">
                <h3>Pending Deposits & Withdrawals</h3>
                <table id="pendingTable">
                    <thead><tr><th>User</th><th>Type</th><th>Amount</th><th>Method</th><th>Account</th><th>Action</th></tr></thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
    
    <script>
        let isAdmin = false;
        
        async function adminLogin() {
            const pass = document.getElementById('adminPass').value;
            const res = await fetch('/admin/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ password: pass })
            });
            const data = await res.json();
            if (data.success) {
                isAdmin = true;
                document.getElementById('loginScreen').style.display = 'none';
                document.getElementById('adminPanel').style.display = 'block';
                loadUsers();
                loadPendingTransactions();
            } else {
                alert('Invalid password');
            }
        }
        
        async function loadUsers() {
            const res = await fetch('/api/admin/users');
            const users = await res.json();
            const tbody = document.querySelector('#usersTable tbody');
            tbody.innerHTML = '';
            users.forEach(user => {
                const row = tbody.insertRow();
                row.insertCell(0).innerText = user.fullname;
                row.insertCell(1).innerText = user.email;
                row.insertCell(2).innerText = user.country;
                row.insertCell(3).innerHTML = `<input type="number" id="bal_${user.id}" value="${user.balance}" style="width:100px;">`;
                row.insertCell(4).innerText = user.referrals.length;
                row.insertCell(5).innerHTML = `<button onclick="updateBalance('${user.id}')">Update</button>`;
            });
        }
        
        async function updateBalance(userId) {
            const newBalance = document.getElementById(`bal_${userId}`).value;
            const res = await fetch('/api/admin/update-balance', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ userId, newBalance, transactionId: null, action: 'admin_edit' })
            });
            const data = await res.json();
            if (data.success) alert('Balance updated');
            else alert('Error');
        }
        
        async function loadPendingTransactions() {
            const res = await fetch('/api/admin/pending-transactions');
            const transactions = await res.json();
            const tbody = document.querySelector('#pendingTable tbody');
            tbody.innerHTML = '';
            for (const tx of transactions) {
                // Fetch user name
                const usersRes = await fetch('/api/admin/users');
                const users = await usersRes.json();
                const user = users.find(u => u.id === tx.userId);
                const row = tbody.insertRow();
                row.insertCell(0).innerText = user ? user.fullname : 'Unknown';
                row.insertCell(1).innerText = tx.type;
                row.insertCell(2).innerText = tx.amount;
                row.insertCell(3).innerText = tx.paymentMethod || tx.method;
                row.insertCell(4).innerText = tx.accountNumber || tx.accountNumber;
                row.insertCell(5).innerHTML = `
                    <button class="approve-btn" onclick="processTransaction('${tx.id}', 'approve', ${tx.amount}, '${tx.userId}', '${tx.type}')">Approve</button>
                    <button class="reject-btn" onclick="processTransaction('${tx.id}', 'reject', ${tx.amount}, '${tx.userId}', '${tx.type}')">Reject</button>
                `;
            }
        }
        
        async function processTransaction(txId, action, amount, userId, type) {
            let newBalance = 0;
            if (action === 'approve' && type === 'deposit') {
                // Add amount to user balance
                const usersRes = await fetch('/api/admin/users');
                const users = await usersRes.json();
                const user = users.find(u => u.id === userId);
                newBalance = user.balance + amount;
            } else if (action === 'approve' && type === 'withdraw') {
                // Balance already deducted, just mark completed
                const usersRes = await fetch('/api/admin/users');
                const users = await usersRes.json();
                const user = users.find(u => u.id === userId);
                newBalance = user.balance; // Keep as is
            } else if (action === 'reject' && type === 'withdraw') {
                // Refund the deducted amount
                const usersRes = await fetch('/api/admin/users');
                const users = await usersRes.json();
                const user = users.find(u => u.id === userId);
                newBalance = user.balance + amount;
            } else if (action === 'reject' && type === 'deposit') {
                const usersRes = await fetch('/api/admin/users');
                const users = await usersRes.json();
                const user = users.find(u => u.id === userId);
                newBalance = user.balance;
            }
            
            const res = await fetch('/api/admin/update-balance', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ userId, newBalance, transactionId: txId, action })
            });
            const data = await res.json();
            if (data.success) {
                alert(`Transaction ${action}d`);
                loadPendingTransactions();
                loadUsers();
            } else {
                alert('Error');
            }
        }
        
        function showTab(tab) {
            document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            if (tab === 'users') {
                document.getElementById('usersPanel').classList.add('active');
                document.querySelector('.tabs .tab:first-child').classList.add('active');
            } else {
                document.getElementById('transactionsPanel').classList.add('active');
                document.querySelector('.tabs .tab:last-child').classList.add('active');
            }
        }
        
        function logoutAdmin() {
            document.getElementById('loginScreen').style.display = 'block';
            document.getElementById('adminPanel').style.display = 'none';
            isAdmin = false;
        }
    </script>
</body>
</html>
